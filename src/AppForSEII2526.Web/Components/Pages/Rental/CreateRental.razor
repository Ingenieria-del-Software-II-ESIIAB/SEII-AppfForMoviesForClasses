@page "/rentals/createrental"
@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForMoviesAPIClient apiclient
@inject ILogger<CreateRental> logger
@inject RentalStateContainer rentalState

@attribute [Authorize]

<h3>Create Rental</h3>

@* rental is the object that will be edited thanks to the form *@
<EditForm Model="rental" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.NameCustomer" class="form-control" id="Name" />
                <label for="Name">Name </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.SurnameCustomer" class="form-control" id="Surname" />
                <label for="Name">Name </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.DeliveryAddress" class="form-control" id="DeliveryAddress" />
                <label for="DeliveryAddress">Delivery Address</label>
            </div>
        </div>
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@rental.PaymentMethod" id="PaymentMethod">
                    <option value="@PaymentMethodType.CreditCard" default> CreditCard</option>
                    <option value="@PaymentMethodType.PayPal"> PayPal</option>
                    <option value="@PaymentMethodType.Cash"> Cash</option>
                </InputSelect>
                <label for="PaymentMethod">Payment Method</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to rent the movies*@
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@rentalButtonDisabled">
                    Rent your movies
                </button>
            </div>
        </div>
    </div>
    <h4>Rental detail</h4>
    <p><b>Date from:</b> @rental.RentalDateFrom.ToString("dd/MM/yyyy") <b>to:</b> @rental.RentalDateTo.ToString("dd/MM/yyyy")</p>
    <p>
        <b>Total price:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyRentalItems" id="ModifyMovies">
            Modify movies
        </button>
    </p>
    
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Genre</th>
                    <th>Price For Renting</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in rental.RentalItems) {
                    <tr id="MovieData_@item.Title">
                        <td>@item.Title</td>
                        <td>@item.Genre</td>
                        <td>@item.PriceForRenting</td>
                        <td><InputText @bind-Value="item.Description" class="form-control" id="@($"description_{item.MovieID}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to rent*@
@if (DialogIsOpen)
{
    <Dialog Caption="Rental movies"
    Message="Do you want to proceed to rent the selected movies?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    //rentalbutton will be disabled if there are not movies in the renting cart
    private bool rentalButtonDisabled { get { return (rental.RentalItems == null || rental.RentalItems.Count == 0); } }
    private bool DialogIsOpen;
    private decimal TotalCost { 
        get {
            int days = (rental.RentalDateTo.DateTime - rental.RentalDateFrom.DateTime).Days;
            double price = rental.RentalItems.Sum(ri => ri.PriceForRenting * days);
            return Convert.ToDecimal(price);
        }
    }
    private void ModifyRentalItems() {
        navigation.NavigateTo("/rental/selectmoviesforrental");
    }
    private RentalForCreateDTO rental => rentalState.Rental;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk) {

        DialogIsOpen = false;
        if (isOk) {
            // Process the data introduced by the user if they are valid
            if (rental.RentalItems.Count > 0) {
                try {
                    var rented = await apiclient.CreateRentalAsync(rental);
                    rentalState.RentalProcessed();
                    navigation.NavigateTo($"/rental/detailrental/?RentalID={rented.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation) {

                    if (apiexceptionvalidation.Result.Errors.Values != null) {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception) {
                    //we need to inform user that there was some other error while processing the request
                    messageError = "Error while processing your request, please try again later!";

                }

            }
        }
    }

    protected override async Task OnInitializedAsync() {

        if (authenticationState is not null) {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null) {
                if (user.Identity is not null && user.Identity.IsAuthenticated) {
                    rental.UserNameCustomer = user.Identity.Name;
                }
            }
            rental.NameCustomer = rental.NameCustomer == null ? "" : rental.NameCustomer;
            rental.SurnameCustomer = rental.SurnameCustomer == null ? "" : rental.SurnameCustomer;
            rental.DeliveryAddress = rental.DeliveryAddress == null ? "" : rental.DeliveryAddress;

        }
    }


    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
 }
